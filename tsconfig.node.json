{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "scheduler/tracing": [
        "./scheduler-tracing.d.ts"
      ]
    },
    "lib": [
      "ESNext",
      "ESNext.Disposable",
      "DOM"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "vite.config.ts"
  ]
}
